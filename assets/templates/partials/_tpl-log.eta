<template id="tpl-log-tab">
  <div class="subpanel-toolbar">
    <button class="clear">Clear</button>
    <div class="spacer"></div>
  </div>
  <ul class="event-list"></ul>
</template>

<template id="tpl-log-event">
  <li class="event">
    <span class="ts mono"></span>
    <span class="lvl"></span>
    <span class="msg"></span>
  </li>
</template>
