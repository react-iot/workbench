# ESP32 Workbench — environment config. Copy to .env and edit.
# Loaded via --env-file (see deno.json start/dev tasks).

# --- MCP endpoint (POST /mcp) ---
# Optional bearer token. If unset, /mcp is OPEN to anyone who can reach the
# server — intended for a trusted LAN. Set a long random value if the LAN isn't
# trusted. Clients must then send:  Authorization: Bearer <token>
# MCP_TOKEN=change-me-to-a-long-random-string

# Disable the MCP endpoint entirely.
# MCP_DISABLED=1

# Comma-separated Origin allowlist. Only needed for BROWSER-based MCP clients;
# non-browser clients (Claude, MCP Inspector, curl) send no Origin and are
# allowed. A browser Origin is rejected unless listed here (DNS-rebinding guard).
# MCP_ALLOWED_ORIGINS=http://localhost:4000
